APP_NAME=Vulnerability Detection API
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

API_V1_PREFIX=/api/v1

MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=vuln_scanner
MONGODB_SCANS_COLLECTION=scans
USE_IN_MEMORY_REPOSITORY=false

JWT_SECRET_KEY=change-this-dev-secret

MODEL_NAME_OR_PATH=microsoft/codebert-base
MODEL_DEVICE=cpu
MODEL_VULNERABILITY_THRESHOLD=0.8

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=AdminPass123

MAX_UPLOAD_SIZE_BYTES=5242880
LOG_LEVEL=INFO

CORS_ALLOWED_ORIGINS_RAW=http://localhost:3000
